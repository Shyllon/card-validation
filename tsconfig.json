{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,            
    "esModuleInterop": true,   
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "node"]  // Tells TS to recognize describe/expect
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}